# Copy this file to ".env" and fill it in. ".env" is gitignored — never commit it.

# Your Supabase project URL (same one the app uses).
SUPABASE_URL=https://vldxennmrjnfhrvrlzuh.supabase.co

# Supabase SERVICE ROLE key — Dashboard → Project Settings → API → "service_role".
# This is a backend-only secret (it can write your data). Used only for the
# nightly write step (Stage 2). Leave blank for the dry-run scrape (Stage 1).
SUPABASE_SERVICE_KEY=

# Where Playwright stores your logged-in portal session. Created by `npm run login`.
PROFILE_DIR=./profile
